---
import { getCollection } from 'astro:content';
import site from '../../site.config.json';

const posts = (await getCollection('news')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const year = new Date().getFullYear();
const R2_BASE = (import.meta.env.PUBLIC_R2_BASE ?? 'https://pub-c7a09e1ddb7c45e6a38fcdca1e4b6897.r2.dev').replace(/\/$/, '');
const imgSrc = (key?: string) => key ? `${R2_BASE}/${key}` : '';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>News & Insights -- {site.siteName}</title>
    <meta name="description" content={`Latest news, guides and insights from ${site.siteName} and Voice Recognition Australia.`} />
    <link rel="canonical" href={`${site.domain}/news`} />
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#fff;color:#0f172a;line-height:1.6}
      header{border-bottom:1px solid #e2e8f0;padding:14px 24px;display:flex;align-items:center;justify-content:space-between}
      header a.logo{display:inline-block}
      header img{height:40px;width:auto;display:block}
      header a.home-link{font-size:14px;color:#1a2f5e;text-decoration:none;font-weight:600}
      header a.home-link:hover{text-decoration:underline}
      .wrap{max-width:1000px;margin:0 auto;padding:56px 24px 80px}
      .page-header{margin-bottom:48px}
      .page-header h1{font-size:36px;letter-spacing:-0.02em;margin:0 0 10px}
      .page-header p{font-size:16px;color:#475569;margin:0}
      .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
      .card{border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;transition:box-shadow .15s;text-decoration:none;color:inherit;display:flex;flex-direction:column}
      .card:hover{box-shadow:0 8px 32px rgba(0,0,0,.08)}
      .card-img{aspect-ratio:16/9;overflow:hidden;background:#f1f5f9}
      .card-img img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .3s}
      .card:hover .card-img img{transform:scale(1.03)}
      .card-img-placeholder{width:100%;height:100%;background:linear-gradient(135deg,#1a2f5e 0%,#2d4a8a 100%)}
      .card-body{padding:20px;flex:1;display:flex;flex-direction:column}
      .card-date{font-size:12px;color:#94a3b8;margin-bottom:8px}
      .card-title{font-size:17px;font-weight:700;color:#0f172a;margin:0 0 10px;line-height:1.3}
      .card-desc{font-size:14px;color:#475569;margin:0 0 16px;flex:1;line-height:1.5}
      .card-link{font-size:13px;font-weight:700;color:#f59e0b;text-decoration:none}
      .empty{text-align:center;padding:80px 24px;color:#94a3b8}
      .empty h2{font-size:22px;color:#475569;margin:0 0 8px}
      footer{border-top:1px solid #e2e8f0;padding:24px;text-align:center;font-size:13px;color:#94a3b8}
      footer a{color:#1a2f5e;text-decoration:none}
      @media(max-width:720px){.grid{grid-template-columns:1fr}}
      @media(max-width:960px) and (min-width:721px){.grid{grid-template-columns:repeat(2,1fr)}}
    </style>
  </head>
  <body>
    <header>
      <a class="logo" href="/"><img src="/logo.jpg" alt={site.siteName} /></a>
      <a class="home-link" href="/">← Back to home</a>
    </header>

    <div class="wrap">
      <div class="page-header">
        <h1>News &amp; Insights</h1>
        <p>Guides, updates and practical advice from {site.siteName}.</p>
      </div>

      {posts.length === 0 ? (
        <div class="empty">
          <h2>No posts yet</h2>
          <p>Check back soon.</p>
        </div>
      ) : (
        <div class="grid">
          {posts.map(post => (
            <a class="card" href={`/news/${post.slug}`}>
              <div class="card-img">
                {post.data.heroImage
                  ? <img src={imgSrc(post.data.heroImage)} alt={post.data.heroImageAlt ?? post.data.title} loading="lazy" decoding="async" />
                  : <div class="card-img-placeholder"></div>
                }
              </div>
              <div class="card-body">
                <div class="card-date">{new Date(post.data.date).toLocaleDateString('en-AU', { day:'numeric', month:'long', year:'numeric' })}</div>
                <div class="card-title">{post.data.title}</div>
                <div class="card-desc">{post.data.metaDescription}</div>
                <span class="card-link">Read more &#8594;</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>

    <footer>
      <a href="/">{site.siteName}</a> &nbsp;·&nbsp;
      <a href="/about">About</a> &nbsp;·&nbsp;
      <a href="/privacy">Privacy</a> &nbsp;·&nbsp;
      <a href="/terms">Terms</a> &nbsp;·&nbsp;
      &copy; {year} Voice Recognition Australia
    </footer>
  </body>
</html>
