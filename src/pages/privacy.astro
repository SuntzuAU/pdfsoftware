---
import site from "../site.config.json";
const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Privacy Policy -- {site.siteName}</title>
    <link rel="canonical" href={`${site.domain}/privacy`} />
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#fff;color:#0f172a;line-height:1.7}
      header{border-bottom:1px solid #e2e8f0;padding:14px 24px}
      header a{display:inline-block}
      header img{height:40px;width:auto;display:block}
      .wrap{max-width:760px;margin:0 auto;padding:48px 24px}
      h1{font-size:32px;letter-spacing:-0.02em;margin:0 0 8px}
      h2{font-size:18px;margin:32px 0 8px}
      p,li{font-size:15px;color:#334155}
      .meta{font-size:13px;color:#94a3b8;margin-bottom:40px}
      footer{border-top:1px solid #e2e8f0;padding:24px;text-align:center;font-size:13px;color:#94a3b8}
      footer a{color:#1a2f5e;text-decoration:none}
    </style>
  </head>
  <body>
    <header><a href="/"><img src="/logo.jpg" alt={site.siteName} /></a></header>
    <div class="wrap">
      <h1>Privacy Policy</h1>
      <p class="meta">Last updated: March 2026 &nbsp;·&nbsp; {site.siteName}</p>
      <p>This website is operated by Voice Recognition Australia Pty Ltd. We are committed to protecting your privacy in accordance with the Australian Privacy Act 1988 and the Australian Privacy Principles.</p>
      <h2>What we collect</h2>
      <p>When you submit an enquiry through this site we collect your name, email address, organisation name, and any information you include in your message.</p>
      <h2>How we use it</h2>
      <p>We use your information solely to respond to your enquiry and provide you with relevant product information. We do not sell or share your personal information with third parties except where required by law.</p>
      <h2>Cookies</h2>
      <p>This site may use basic analytics cookies to understand visitor behaviour. We do not use advertising or tracking cookies.</p>
      <h2>Your rights</h2>
      <p>You have the right to access, correct, or request deletion of your personal information. Contact us via the form on the home page.</p>
    </div>
    <footer><a href="/">{site.siteName}</a> &nbsp;·&nbsp; <a href="/terms">Terms</a> &nbsp;·&nbsp; &copy; {year} Voice Recognition Australia</footer>
  </body>
</html>
