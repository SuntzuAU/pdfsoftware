---
import site from "../site.config.json";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found -- {site.siteName}</title>
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#fff;color:#0f172a;line-height:1.6;min-height:100vh;display:flex;flex-direction:column}
      header{border-bottom:1px solid #e2e8f0;padding:14px 24px}
      header a{display:inline-block}
      header img{height:40px;width:auto;display:block}
      .wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:64px 24px}
      .code{font-size:96px;font-weight:800;color:#e2e8f0;line-height:1;margin:0 0 8px;letter-spacing:-0.04em}
      h1{font-size:28px;font-weight:700;margin:0 0 12px;color:#0f172a}
      p{font-size:16px;color:#475569;margin:0 0 32px;max-width:420px}
      .btn{display:inline-block;background:#f59e0b;color:#0f172a;font-weight:700;font-size:15px;padding:14px 28px;border-radius:10px;text-decoration:none}
      footer{border-top:1px solid #e2e8f0;padding:20px 24px;text-align:center;font-size:13px;color:#94a3b8}
      footer a{color:#1a2f5e;text-decoration:none}
    </style>
  </head>
  <body>
    <header><a href="/"><img src="/logo.jpg" alt={site.siteName} /></a></header>
    <div class="wrap">
      <div class="code">404</div>
      <h1>Page not found</h1>
      <p>The page you're looking for doesn't exist or may have moved.</p>
      <a class="btn" href="/">Back to home</a>
    </div>
    <footer><a href="/">{site.siteName}</a> &nbsp;·&nbsp; <a href="/privacy">Privacy</a> &nbsp;·&nbsp; <a href="/terms">Terms</a></footer>
  </body>
</html>
